{
  "openapi": "3.0.3",
  "info": {
    "title": "sharedmobility.ch API",
    "description": "Access sharedmobility.ch data via RESTful API. The sharedmobility.ch platform is Switzerland's national shared mobility platform showing location and availability of all participating shared mobility providers. The data encompasses various mobility service providers including cars, scooters, bikes and more, available as Open Data.",
    "version": "1.0.0",
    "contact": {
      "email": "geoinformation@bfe.admin.ch"
    },
    "license": {
      "name": "Open Data",
      "url": "https://opendata.swiss/en/dataset/standorte-und-verfugbarkeit-von-shared-mobility-angeboten"
    }
  },
  "externalDocs": {
    "description": "API Documentation on GitHub",
    "url": "https://github.com/SFOE/sharedmobility/blob/main/Sharedmobility.ch-API.md"
  },
  "servers": [
    {
      "url": "https://sharedmobility.ch/api",
      "description": "Production server"
    }
  ],
  "paths": {
    "/attributes": {
      "get": {
        "summary": "Get attributes",
        "description": "Retrieve attribute information for shared mobility data",
        "operationId": "getAttributes",
        "tags": [
          "Attributes"
        ],
        "responses": {
          "200": {
            "description": "Successful response with attributes data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "attributes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string"
                          },
                          "description": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/find": {
      "get": {
        "summary": "Find shared mobility assets",
        "description": "Search and find shared mobility assets based on location, type, and other criteria",
        "operationId": "findAssets",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "description": "Latitude coordinate",
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": -90,
              "maximum": 90
            }
          },
          {
            "name": "lon",
            "in": "query",
            "description": "Longitude coordinate",
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": -180,
              "maximum": 180
            }
          },
          {
            "name": "radius",
            "in": "query",
            "description": "Search radius in meters",
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": 0
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Type of shared mobility asset (e.g., bike, scooter, car)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "provider",
            "in": "query",
            "description": "Provider ID or name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with found assets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "example": "FeatureCollection"
                    },
                    "features": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Asset"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/identify": {
      "get": {
        "summary": "Identify specific asset",
        "description": "Get detailed information about a specific shared mobility asset by ID",
        "operationId": "identifyAsset",
        "tags": [
          "Assets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "Asset identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with asset details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Asset"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Asset not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/providers": {
      "get": {
        "summary": "Get list of providers",
        "description": "Retrieve a list of all shared mobility providers on the platform",
        "operationId": "getProviders",
        "tags": [
          "Providers"
        ],
        "responses": {
          "200": {
            "description": "Successful response with providers list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "providers": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Provider"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/regions": {
      "get": {
        "summary": "Get regions",
        "description": "Retrieve information about geographical regions covered by shared mobility services",
        "operationId": "getRegions",
        "tags": [
          "Regions"
        ],
        "responses": {
          "200": {
            "description": "Successful response with regions data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "example": "FeatureCollection"
                    },
                    "features": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Region"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Asset": {
        "type": "object",
        "description": "A shared mobility asset (vehicle, bike, scooter, etc.)",
        "properties": {
          "type": {
            "type": "string",
            "example": "Feature"
          },
          "id": {
            "type": "string",
            "description": "Unique identifier for the asset"
          },
          "geometry": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "example": "Point"
              },
              "coordinates": {
                "type": "array",
                "items": {
                  "type": "number"
                },
                "minItems": 2,
                "maxItems": 3,
                "example": [
                  7.4474,
                  46.948
                ]
              }
            }
          },
          "properties": {
            "type": "object",
            "properties": {
              "provider": {
                "type": "string",
                "description": "Name of the mobility provider"
              },
              "type": {
                "type": "string",
                "description": "Type of vehicle",
                "enum": [
                  "bike",
                  "scooter",
                  "car",
                  "moped",
                  "other"
                ]
              },
              "availability": {
                "type": "string",
                "description": "Current availability status"
              },
              "battery_level": {
                "type": "number",
                "description": "Battery level percentage (0-100)",
                "minimum": 0,
                "maximum": 100
              },
              "name": {
                "type": "string",
                "description": "Name or identifier of the asset"
              }
            }
          }
        }
      },
      "Provider": {
        "type": "object",
        "description": "A shared mobility service provider",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the provider"
          },
          "name": {
            "type": "string",
            "description": "Name of the provider"
          },
          "type": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Types of mobility services offered"
          },
          "website": {
            "type": "string",
            "format": "uri",
            "description": "Provider's website URL"
          },
          "contact": {
            "type": "object",
            "properties": {
              "email": {
                "type": "string",
                "format": "email"
              },
              "phone": {
                "type": "string"
              }
            }
          },
          "coverage_area": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Regions or cities covered by the provider"
          }
        }
      },
      "Region": {
        "type": "object",
        "description": "A geographical region with shared mobility coverage",
        "properties": {
          "type": {
            "type": "string",
            "example": "Feature"
          },
          "id": {
            "type": "string",
            "description": "Unique identifier for the region"
          },
          "geometry": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "Polygon",
                  "MultiPolygon"
                ]
              },
              "coordinates": {
                "type": "array",
                "items": {
                  "type": "array"
                }
              }
            }
          },
          "properties": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Name of the region"
              },
              "providers": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "List of provider IDs operating in this region"
              },
              "asset_count": {
                "type": "integer",
                "description": "Number of assets available in the region"
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "description": "Error response",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "details": {
            "type": "string",
            "description": "Additional error details"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Attributes",
      "description": "Operations related to data attributes"
    },
    {
      "name": "Search",
      "description": "Search and find shared mobility assets"
    },
    {
      "name": "Assets",
      "description": "Operations on individual shared mobility assets"
    },
    {
      "name": "Providers",
      "description": "Operations related to mobility service providers"
    },
    {
      "name": "Regions",
      "description": "Operations related to geographical regions"
    }
  ]
}
