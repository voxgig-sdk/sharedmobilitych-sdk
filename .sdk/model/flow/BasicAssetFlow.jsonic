# BasicAssetFlow

main: kit: flow: BasicAssetFlow:
{
  entity: "asset",
  kind: "basic",
  name: "BasicAssetFlow",
  step: [
    {
      input: {
        ref: "asset_ref01",
        srcdatavar: "asset_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-asset_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicAssetFlow"
}